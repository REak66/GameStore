PORT=5050
MONGODB_URI=mongodb://localhost:27017/shopping_db
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=1h
CLIENT_URL=http://localhost:4200

# ── Gmail API (OAuth2) ──────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Desktop app)
# 3. Enable the Gmail API for the project
# 4. Visit https://developers.google.com/oauthplayground
#    → Gear icon → check "Use your own OAuth credentials" and paste your IDs
#    → Scope: https://mail.google.com/
#    → Authorise → Exchange auth code for tokens → copy Refresh Token
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_FROM="GameShop <your_email@gmail.com>"
